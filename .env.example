# Copy to .env and fill in. .env is git-ignored.
#
# Required: Supabase project credentials. Use the SERVICE ROLE key, not anon —
# the Go API needs row-level write access and bypasses RLS.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Required: 32+ char secret used to sign MCP gateway JWTs. Rotate to revoke all
# active MCP sessions.
JWT_SECRET=change-me-to-something-long-and-random

# Optional: lifetime of issued JWTs. Go duration string (e.g. 24h, 30m, 168h).
# Defaults to 24h.
# JWT_TOKEN_TTL=24h

# Optional: host port to expose. Defaults to 7891. Useful if 7891 is in use.
# HOST_PORT=7891
