# Copy to .env and fill in values

# Supabase project URL (from Project Settings → API)
SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase service_role key (from Project Settings → API → service_role)
# Use service_role, NOT anon — the API server needs write access
SUPABASE_KEY=eyJ...

# Random secret for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_random_secret

# HTTP port (default: 7891)
PORT=7891

# Path to built web app (relative to apps/api/ when running with go run)
WEB_DIST_PATH=../../apps/web/dist

# Local directory for uploaded images
IMAGE_DIR=./canvas-images

# Google OAuth client id for "Sign in with Google" (public, not a secret).
# Create at console.cloud.google.com → APIs & Services → Credentials →
# OAuth client ID (type: Web). Add your origins to Authorized JavaScript
# origins (e.g. http://localhost:5173 for dev, https://tandemcanvas.com for
# prod). Leave empty to disable sign-in. The web build needs the same value
# as VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=

# Set to true in production (https) so the session cookie is marked Secure.
# Leave false/unset for local http dev or the cookie won't be stored.
COOKIE_SECURE=false
