# Copy to .env and fill in values

# Supabase project URL (from Project Settings → API)
SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase service_role key (from Project Settings → API → service_role)
# Use service_role, NOT anon — the API server needs write access
SUPABASE_KEY=eyJ...

# Random secret for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_random_secret

# HTTP port (default: 7891)
PORT=7891

# Path to built web app (relative to apps/api/ when running with go run)
WEB_DIST_PATH=../../apps/web/dist

# Local directory for uploaded images
IMAGE_DIR=./canvas-images
