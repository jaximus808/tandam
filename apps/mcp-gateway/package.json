{
  "name": "@jaximus/tandem-mcp",
  "version": "2.0.4",
  "description": "MCP server for Tandem — lets any MCP-aware agent (Claude Code, Cursor, Codex, OpenAI Agents SDK, custom orchestrators) read and write a shared Tandem canvas in real time.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "tandem-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tandem",
    "agent",
    "ai",
    "canvas",
    "claude",
    "openai",
    "codex",
    "cursor",
    "collaboration"
  ],
  "author": "Jaxon Parker (https://www.jaxonp.com)",
  "license": "MIT",
  "homepage": "https://github.com/jaximus808/tandam#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaximus808/tandam.git",
    "directory": "apps/mcp-gateway"
  },
  "bugs": {
    "url": "https://github.com/jaximus808/tandam/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsup": "^8.0.2",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5"
  }
}
